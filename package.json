{
  "name": "localshare",
  "version": "1.0.0",
  "description": "⚡ Ultra-fast WiFi file sharing — no apps, no cloud, no accounts.",
  "main": "server/index.js",
  "bin": { "localshare": "./server/index.js" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yogesh1290/Local-Share.git"
  },
  "bugs": {
    "url": "https://github.com/Yogesh1290/Local-Share/issues"
  },
  "homepage": "https://github.com/Yogesh1290/Local-Share#readme",
  "scripts": {
    "start": "node server/index.js",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "open": "^9.1.0",
    "qrcode": "^1.5.3",
    "ws": "^8.14.2"
  },
  "keywords": ["file-sharing","wifi","local-network","lan","transfer"],
